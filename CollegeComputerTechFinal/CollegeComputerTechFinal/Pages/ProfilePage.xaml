<Page x:Class="CollegeComputerTechFinal.Pages.ProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Личный кабинет" Background="#F0F2F5">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="👤 Личный кабинет" FontSize="28" FontWeight="Bold" 
                   Foreground="#2C3E50" Margin="0,0,0,20"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Карточка пользователя -->
                <Border Background="White" CornerRadius="10" Padding="20" Margin="0,0,0,15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Background="#3498DB" Width="60" Height="60" CornerRadius="30" 
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="А" FontSize="28" Foreground="White" 
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="15,0,0,0">
                            <TextBlock x:Name="txtFullName" FontSize="20" FontWeight="Bold" 
                                       Foreground="#2C3E50"/>
                            <TextBlock x:Name="txtRole" FontSize="14" Foreground="#3498DB"/>
                            <TextBlock x:Name="txtCabinet" FontSize="13" Foreground="#7F8C8D" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Статистика -->
                <Border Background="White" CornerRadius="10" Padding="15" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="📊 Статистика" FontWeight="Bold" FontSize="16" 
                                   Foreground="#2C3E50" Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Background="#E8F8F5" CornerRadius="8" Padding="10" Margin="0,0,5,0">
                                <StackPanel>
                                    <TextBlock x:Name="txtTotalComputers" Text="0" FontSize="20" 
                                               FontWeight="Bold" Foreground="#27AE60"/>
                                    <TextBlock Text="Всего ПК" FontSize="12" Foreground="#7F8C8D"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#FEF9E7" CornerRadius="8" Padding="10" Margin="5,0,5,0">
                                <StackPanel>
                                    <TextBlock x:Name="txtWorkingComputers" Text="0" FontSize="20" 
                                               FontWeight="Bold" Foreground="#F39C12"/>
                                    <TextBlock Text="Работает" FontSize="12" Foreground="#7F8C8D"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#FDEDEC" CornerRadius="8" Padding="10" Margin="5,0,0,0">
                                <StackPanel>
                                    <TextBlock x:Name="txtBrokenComputers" Text="0" FontSize="20" 
                                               FontWeight="Bold" Foreground="#E74C3C"/>
                                    <TextBlock Text="Не работает" FontSize="12" Foreground="#7F8C8D"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Уведомления -->
                <Border Background="White" CornerRadius="10" Padding="15" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="🔔 Последние уведомления" FontWeight="Bold" FontSize="16" 
                                   Foreground="#2C3E50" Margin="0,0,0,10"/>
                        <ListBox x:Name="NotificationsList" MaxHeight="120">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#F8F9FA" CornerRadius="5" Padding="10" Margin="0,0,0,5">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}" FontWeight="Bold" 
                                                       Foreground="#2C3E50" FontSize="13"/>
                                            <TextBlock Text="{Binding Message}" Foreground="#7F8C8D" 
                                                       FontSize="12" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding Date}" Foreground="#95A5A6" 
                                                       FontSize="11" Margin="0,5,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>

                <!-- Сотрудники (только для админа) -->
                <Border x:Name="UsersBorder" Background="White" CornerRadius="10" Padding="15"
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="👥 Сотрудники системы" FontWeight="Bold" FontSize="16" 
                                   Foreground="#2C3E50" Margin="0,0,0,10"/>
                        <ListBox x:Name="UsersList" MaxHeight="150">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#F8F9FA" CornerRadius="5" Padding="10" Margin="0,0,0,5">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding FullName}" FontWeight="Bold" 
                                                           Foreground="#2C3E50" FontSize="13"/>
                                                <TextBlock Text="{Binding Role}" Foreground="#7F8C8D" 
                                                           FontSize="12"/>
                                                <TextBlock Text="{Binding Cabinet}" Foreground="#95A5A6" 
                                                           FontSize="11"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Text="{Binding Status}" 
                                                       Foreground="#27AE60" FontSize="12" 
                                                       VerticalAlignment="Center" Margin="10,0,0,0"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>