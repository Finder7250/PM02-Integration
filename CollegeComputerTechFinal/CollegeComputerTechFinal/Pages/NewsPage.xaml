<Page x:Class="CollegeComputerTechFinal.Pages.NewsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Новости" Background="#F0F2F5">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <TextBlock Text="Новости колледжа" FontSize="28" FontWeight="Bold" Foreground="#2C3E50"/>
            <Button Content="+ Добавить новость" Margin="30,0,0,0" 
                    Background="#27AE60" Foreground="White" BorderThickness="0"
                    Padding="15,8" 
                    FontWeight="Bold"
                    Click="AddNews_Click" />
        </StackPanel>

        <ListBox Grid.Row="1" x:Name="NewsList">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="{Binding Title}" FontSize="16" FontWeight="Bold" 
                                       Foreground="#2C3E50"/>
                            <TextBlock Text="{Binding Date}" FontSize="11" 
                                       Foreground="#7F8C8D" Margin="0,5,0,5"/>
                            <TextBlock Text="{Binding Text}" TextWrapping="Wrap" 
                                       Foreground="#333333"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Page>