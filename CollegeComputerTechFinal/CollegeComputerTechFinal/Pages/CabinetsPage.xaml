<Page x:Class="CollegeComputerTechFinal.Pages.CabinetsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Кабинеты" Background="#F0F2F5">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <TextBlock Text="Кабинеты информатики" FontSize="28" FontWeight="Bold" 
                       Foreground="#2C3E50"/>
            <Button Content="📊 Экспорт в Excel" Margin="30,0,0,0" 
                    Background="#27AE60" Foreground="White" BorderThickness="0"
                    Padding="15,8" FontWeight="Bold" Click="ExportToExcel_Click"/>
        </StackPanel>

        <ListBox Grid.Row="1" x:Name="CabinetsList" SelectionChanged="CabinetsList_SelectionChanged">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="{Binding Number}" FontSize="18" FontWeight="Bold" 
                                       Foreground="#2C3E50"/>
                            <TextBlock Text="{Binding Location}" Foreground="#7F8C8D" Margin="0,5,0,5"/>
                            <TextBlock Text="{Binding Responsible}" Foreground="#333333"/>
                            <TextBlock Text="{Binding ArmsCount, StringFormat='Компьютеров: {0}'}" 
                                       Foreground="#3498DB" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Page>