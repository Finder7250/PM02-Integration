<Window x:Class="CollegeComputerTechFinal.CabinetDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Компьютеры кабинета" Height="450" Width="600"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="txtCabinetTitle" FontSize="20" FontWeight="Bold"
                   Foreground="#2C3E50" Margin="0,0,0,10"/>

        <ListBox Grid.Row="1" x:Name="ComputersList" Margin="0,0,0,10">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Background="White" CornerRadius="8" Padding="10" Margin="0,0,0,5">
                        <StackPanel>
                            <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="14" Foreground="#2C3E50"/>
                            <TextBlock Text="{Binding IpAddress}" Foreground="#7F8C8D" FontSize="12"/>
                            <TextBlock Text="{Binding Status}" Foreground="#3498DB" FontSize="12" Margin="0,5,0,0"/>

                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                <Button Content="✅ Работает" Width="85" Height="28" Margin="0,0,5,0"
            Background="#27AE60" Foreground="White" BorderThickness="0"
            Click="SetStatusWorking_Click" Tag="{Binding Id}"/>
                                <Button Content="⚠️ Ремонт" Width="85" Height="28" Margin="0,0,5,0"
            Background="#E67E22" Foreground="White" BorderThickness="0"
            Click="SetStatusRepair_Click" Tag="{Binding Id}"/>
                                <Button Content="❌ Не работает" Width="85" Height="28" Margin="0,0,5,0"
            Background="#E74C3C" Foreground="White" BorderThickness="0"
            Click="SetStatusBroken_Click" Tag="{Binding Id}"/>
                                <Button Content="📋 Подробнее" Width="85" Height="28"
            Background="#34495E" Foreground="White" BorderThickness="0"
            Click="Details_Click" Tag="{Binding Id}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Window>