<Window x:Class="CollegeComputerTechFinal.ComputerDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Детали компьютера" Height="450" Width="500"
        WindowStartupLocation="CenterScreen" Background="#F0F2F5">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="txtTitle" Grid.Row="0" FontSize="22" FontWeight="Bold" 
                   Foreground="#2C3E50" Margin="0,0,0,20"/>

        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="20">
            <StackPanel>
                <TextBlock Text="Общая информация" FontWeight="Bold" FontSize="16" Foreground="#2C3E50" Margin="0,0,0,15"/>

                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Имя ПК:" FontWeight="Bold" Foreground="#7F8C8D"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="txtName" Foreground="#333333"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="IP-адрес:" FontWeight="Bold" Foreground="#7F8C8D"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="txtIp" Foreground="#333333"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Инв. номер:" FontWeight="Bold" Foreground="#7F8C8D"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" x:Name="txtInv" Foreground="#333333"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Тип устройства:" FontWeight="Bold" Foreground="#7F8C8D"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" x:Name="txtType" Foreground="#333333"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Статус:" FontWeight="Bold" Foreground="#7F8C8D"/>
                    <TextBlock Grid.Row="4" Grid.Column="1" x:Name="txtStatus" Foreground="#27AE60" FontWeight="Bold"/>

                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Кабинет:" FontWeight="Bold" Foreground="#7F8C8D"/>
                    <TextBlock Grid.Row="5" Grid.Column="1" x:Name="txtCabinet" Foreground="#333333"/>

                    <TextBlock Grid.Row="6" Grid.Column="0" Text="Ответственный:" FontWeight="Bold" Foreground="#7F8C8D"/>
                    <TextBlock Grid.Row="6" Grid.Column="1" x:Name="txtResponsible" Foreground="#333333"/>

                    <TextBlock Grid.Row="7" Grid.Column="0" Text="Публичный IP:" FontWeight="Bold" Foreground="#7F8C8D"/>
                    <TextBlock Grid.Row="7" Grid.Column="1" x:Name="txtPublicIP" Foreground="#27AE60" FontWeight="Bold"/>
                </Grid>

                <Border Background="#F0F2F5" CornerRadius="8" Padding="15" Margin="0,10,0,0">
                    <StackPanel>
                        <TextBlock Text="Характеристики" FontWeight="Bold" FontSize="14" Foreground="#2C3E50" Margin="0,0,0,10"/>
                        <TextBlock x:Name="txtCpu" Margin="0,2"/>
                        <TextBlock x:Name="txtRam" Margin="0,2"/>
                        <TextBlock x:Name="txtDisk" Margin="0,2"/>
                    </StackPanel>
                </Border>

                <Button Content="Закрыть" Width="100" Height="30" Margin="0,20,0,0" 
                        HorizontalAlignment="Center" Click="Close_Click"
                        Background="#3498DB" Foreground="White" BorderThickness="0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>